<Page
    x:Class="ProjectDashboard.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:ProjectDashboard.Helpers"
    xmlns:models="clr-namespace:ProjectDashboard.Models">

    <Page.Resources>
        <helpers:RelativeTimeConverter x:Key="RelativeTimeConverter" />
    </Page.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Summary bar (clickable filters, aligned to filter bar below) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <!-- Group 1: Total + Dirty = 180px (aligns with Category dropdown) -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12,8" Width="86" Margin="0,0,8,0"
                    Cursor="Hand" ToolTip="Show all projects">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterAllCommand}" />
                </Border.InputBindings>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Total: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12,8" Width="86" Margin="0,0,12,0"
                    Cursor="Hand" ToolTip="Show only dirty projects">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterDirtyCommand}" />
                </Border.InputBindings>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Dirty: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DirtyCount}" FontWeight="SemiBold" FontSize="12"
                               Foreground="#E8A317" />
                </StackPanel>
            </Border>

            <!-- Group 2: Tasks + Issues = 180px (aligns with Sort dropdown) -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12,8" Width="86" Margin="0,0,8,0"
                    Cursor="Hand" ToolTip="Show projects with pending tasks">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterTodosCommand}" />
                </Border.InputBindings>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Tasks: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TodoCount}" FontWeight="SemiBold" FontSize="12"
                               Foreground="#5B9BD5" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12,8" Width="86" Margin="0,0,12,0"
                    Cursor="Hand" ToolTip="Show projects with open issues">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterIssuesCommand}" />
                </Border.InputBindings>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Issues: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding IssueCount}" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Group 3: Hidden + Refresh + New = 280px (aligns with Search box) -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12,8" Width="86" Margin="0,0,8,0"
                    Cursor="Hand" ToolTip="Show hidden projects">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding FilterHiddenCommand}" />
                </Border.InputBindings>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Hidden: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding HiddenCount}" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>
            <ui:Button Content="Refresh" FontSize="12" Padding="8,6"
                       Icon="{ui:SymbolIcon ArrowSync24}"
                       Command="{Binding ForceRefreshCommand}"
                       Width="90" Margin="0,0,8,0" />
            <ui:Button Content="New" FontSize="12" Padding="8,6"
                       Icon="{ui:SymbolIcon Add24}"
                       Command="{Binding NewProjectCommand}"
                       Width="80" />
        </StackPanel>

        <!-- Filter + Sort bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Width="180" Margin="0,0,12,0" />

            <ComboBox ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort}"
                      Width="180" Margin="0,0,12,0" />

            <ui:TextBox PlaceholderText="Search projects..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Width="272" />
        </StackPanel>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="2"
                   Text="Loading projects..."
                   FontSize="16"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Visibility="{Binding LoadProjectsCommand.IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- Card grid -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <ItemsControl ItemsSource="{Binding FilteredProjects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ProjectInfo}">
                        <Border Width="320" MinHeight="200" Margin="8"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Cursor="Hand">
                            <Border.Tag>
                                <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Page}" />
                            </Border.Tag>
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Open Details"
                                              Command="{Binding Tag.OpenProjectCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="Refresh Status"
                                              Command="{Binding Tag.RefreshSingleCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <Separator />
                                    <MenuItem Header="Open on GitHub"
                                              Command="{Binding Tag.OpenGitHubCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="Open Folder"
                                              Command="{Binding Tag.OpenFolderCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <Separator />
                                    <MenuItem Header="Hide Project"
                                              Command="{Binding Tag.HideProjectCommand}"
                                              CommandParameter="{Binding DataContext}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.Manifest.Status}" Value="hidden">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                    </MenuItem>
                                    <MenuItem Header="Unhide Project"
                                              Command="{Binding Tag.UnhideProjectCommand}"
                                              CommandParameter="{Binding DataContext}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.Manifest.Status}" Value="hidden">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Display Name -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding DisplayName}"
                                           FontWeight="Bold" FontSize="14"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                                <!-- Version + Status -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock FontSize="12" Margin="0,0,10,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding LatestVersion}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LatestVersion}" Value="">
                                                        <Setter Property="Text" Value="no version" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Border CornerRadius="4" Padding="6,1" Background="#2D7D46">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Manifest.Status}" Value="maintenance">
                                                        <Setter Property="Background" Value="#B8860B" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Manifest.Status}" Value="archived">
                                                        <Setter Property="Background" Value="#666" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Manifest.Status}" Value="experimental">
                                                        <Setter Property="Background" Value="#7B68EE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Manifest.Status}" FontSize="10" Foreground="White" />
                                    </Border>
                                </StackPanel>

                                <!-- Git status -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GitStatus.IsDirty}" Value="True">
                                                        <Setter Property="Fill" Value="#E8A317" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Clean" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GitStatus.IsDirty}" Value="True">
                                                        <Setter Property="Text"
                                                                Value="{Binding GitStatus.ModifiedCount, StringFormat='{}{0} modified'}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Category + Type + Validation + Visibility badges -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Manifest.Category}" FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Manifest.ProjectType}" FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Background" Value="#1E5A8A" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Manifest.ValidationSchedule}" Value="none">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Manifest.ValidationSchedule}" Value="daily">
                                                        <Setter Property="Background" Value="#C0392B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Manifest.ValidationSchedule}" FontSize="10" Foreground="White" />
                                    </Border>
                                    <!-- Visibility badge -->
                                    <Border CornerRadius="4" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2D7D46" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GitStatus.Visibility}" Value="private">
                                                        <Setter Property="Background" Value="#8B4513" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GitStatus.Visibility}" Value="local">
                                                        <Setter Property="Background" Value="#555" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding GitStatus.Visibility}" FontSize="10" Foreground="White" />
                                    </Border>
                                </StackPanel>

                                <!-- Notes (if present) -->
                                <TextBlock Grid.Row="4" Margin="0,6,0,0" FontSize="11"
                                           TextWrapping="Wrap" MaxHeight="36"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Text="{Binding Manifest.Notes}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Manifest.Notes}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Bottom row: last commit + issues -->
                                <DockPanel Grid.Row="5" Margin="0,6,0,0">
                                    <TextBlock DockPanel.Dock="Left" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="{Binding GitStatus.LastCommitDate, Converter={StaticResource RelativeTimeConverter}}" />

                                    <TextBlock DockPanel.Dock="Right" FontSize="11"
                                               HorizontalAlignment="Right"
                                               Foreground="#E8A317">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OpenIssueCount}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding OpenIssueCount, Mode=OneWay}" />
                                        <Run Text=" issues" />
                                    </TextBlock>
                                </DockPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
