<Page
    x:Class="ProjectDashboard.Views.Pages.ProjectDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:ProjectDashboard.Helpers"
    xmlns:local="clr-namespace:ProjectDashboard.ViewModels.Pages">

    <Page.Resources>
        <helpers:RelativeTimeConverter x:Key="RelativeTimeConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="32,20,32,32" MaxWidth="1200">

            <!-- ═══ HEADER ═══ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="{Binding Project.DisplayName}"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding Project.LatestVersion}"
                           FontSize="14" Margin="14,0,0,0"
                           VerticalAlignment="Bottom" Padding="0,0,0,3"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Ellipse Width="10" Height="10" Margin="14,0,6,0" VerticalAlignment="Bottom">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#4CAF50" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Project.GitStatus.IsDirty}" Value="True">
                                    <Setter Property="Fill" Value="#E8A317" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock FontSize="12" VerticalAlignment="Bottom" Padding="0,0,0,4"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="{Binding Project.FullPath}" />
            </StackPanel>

            <!-- ═══ ROW 1: MANIFEST + NOTES (side by side, top priority) ═══ -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Manifest fields (compact) -->
                <Border Grid.Column="0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20,16" Margin="0,0,12,0" MinWidth="380">
                    <StackPanel>
                        <TextBlock Text="Project Manifest" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                <TextBlock Text="Type" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.ProjectTypes}"
                                          SelectedItem="{Binding SelectedProjectType}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="Status" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.Statuses}"
                                          SelectedItem="{Binding SelectedStatus}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Category" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.CategoriesList}"
                                          SelectedItem="{Binding SelectedCategory}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="Validation" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.Schedules}"
                                          SelectedItem="{Binding ValidationSchedule}" FontSize="12" />
                            </StackPanel>
                        </Grid>

                        <ui:Button Content="Save" Appearance="Primary" Margin="0,12,0,0"
                                   HorizontalAlignment="Left"
                                   Command="{Binding SaveManifestCommand}" />
                    </StackPanel>
                </Border>

                <!-- Notes (takes remaining width, multi-line, rendered like markdown) -->
                <Border Grid.Column="1" Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Notes" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="1"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="140"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Code,Consolas,Courier New"
                                 FontSize="12.5"
                                 BorderThickness="0"
                                 Background="Transparent" />
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ ROW 2: RECENT COMMITS (full width) ═══ -->
            <TextBlock Text="Recent Commits" FontWeight="SemiBold" FontSize="15"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,24,0,8" />
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <ItemsControl ItemsSource="{Binding Commits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="4,5" Cursor="Hand"
                                    ToolTip="Click to open on GitHub">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenCommitCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Width="70"
                                               Text="{Binding ShortHash}"
                                               FontFamily="Cascadia Code,Consolas"
                                               FontSize="12"
                                               Foreground="#6CA4D9"
                                               TextDecorations="Underline" />
                                    <TextBlock DockPanel.Dock="Right" MinWidth="70"
                                               Text="{Binding Date, Converter={StaticResource RelativeTimeConverter}}"
                                               FontSize="11"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="12.5"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ═══ ROW 3: GITHUB ISSUES (full width, only if present) ═══ -->
            <TextBlock Text="GitHub Issues" FontWeight="SemiBold" FontSize="15"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,24,0,8" />
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Margin="4,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Issues.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="Text" Value="No open issues" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Issues}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,5" Cursor="Hand"
                                        ToolTip="Click to open on GitHub">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.OpenIssueCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Width="50"
                                                   FontSize="12.5" Foreground="#6CA4D9" TextDecorations="Underline">
                                            <Run Text="#" /><Run Text="{Binding Number, Mode=OneWay}" />
                                        </TextBlock>
                                        <Border DockPanel.Dock="Right"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="8,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding State}" FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ═══ ROW 4: README (collapsible, lower priority) ═══ -->
            <Expander IsExpanded="False" Margin="0,24,0,0">
                <Expander.Header>
                    <TextBlock Text="README" FontWeight="SemiBold" FontSize="15"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </Expander.Header>
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="0,0,8,8" Padding="20">
                    <RichTextBox x:Name="ReadmeRichText"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Segoe UI,Cascadia Code"
                                 FontSize="13" />
                </Border>
            </Expander>

            <!-- ═══ ROW 5: CHANGELOG (collapsible, lower priority) ═══ -->
            <Expander IsExpanded="False" Margin="0,12,0,24">
                <Expander.Header>
                    <TextBlock Text="CHANGELOG" FontWeight="SemiBold" FontSize="15"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </Expander.Header>
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="0,0,8,8" Padding="20">
                    <RichTextBox x:Name="ChangelogRichText"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Segoe UI,Cascadia Code"
                                 FontSize="13" />
                </Border>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
