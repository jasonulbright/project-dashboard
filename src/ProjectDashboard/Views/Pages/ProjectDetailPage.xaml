<Page
    x:Class="ProjectDashboard.Views.Pages.ProjectDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:ProjectDashboard.Helpers"
    xmlns:local="clr-namespace:ProjectDashboard.ViewModels.Pages">

    <Page.Resources>
        <helpers:RelativeTimeConverter x:Key="RelativeTimeConverter" />
    </Page.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="{Binding Project.DisplayName}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding Project.LatestVersion}"
                       FontSize="14" Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <Ellipse Width="10" Height="10" Margin="12,0,0,0" VerticalAlignment="Center">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#4CAF50" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Project.GitStatus.IsDirty}" Value="True">
                                <Setter Property="Fill" Value="#E8A317" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Clean" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Project.GitStatus.IsDirty}" Value="True">
                                <Setter Property="Text" Value="Dirty" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Main content: two columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Left column: README + CHANGELOG -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- README -->
                <Border Grid.Row="0" Margin="0,0,0,8"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="README" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding ReadmeText}"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- CHANGELOG -->
                <Border Grid.Row="1" Margin="0,8,0,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CHANGELOG" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding ChangelogText}"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right column: Commits + Issues -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Git Commits -->
                <Border Grid.Row="0" Margin="0,0,0,8"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Recent Commits" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ListView Grid.Row="1" ItemsSource="{Binding Commits}"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding ShortHash}"
                                                       FontFamily="Cascadia Code,Consolas"
                                                       FontSize="11"
                                                       Foreground="#6CA4D9"
                                                       Margin="0,0,8,0" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding Date, Converter={StaticResource RelativeTimeConverter}}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </DockPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- GitHub Issues -->
                <Border Grid.Row="1" Margin="0,8,0,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="GitHub Issues" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ListView Grid.Row="1" ItemsSource="{Binding Issues}"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontSize="12"
                                                   Foreground="#6CA4D9"
                                                   Margin="0,0,8,0">
                                            <Run Text="#" /><Run Text="{Binding Number, Mode=OneWay}" />
                                        </TextBlock>
                                        <Border DockPanel.Dock="Right"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="6,1"
                                                Margin="8,0,0,0">
                                            <TextBlock Text="{Binding State}" FontSize="10"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </Border>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom: Manifest editor -->
        <Border Grid.Row="2" Margin="0,16,0,0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Project Manifest" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,12" />

                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="Type" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.ProjectTypes}"
                                  SelectedItem="{Binding SelectedProjectType}"
                                  Width="150" />
                    </StackPanel>

                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="Status" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.Statuses}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  Width="150" />
                    </StackPanel>

                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="Category" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.CategoriesList}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  Width="150" />
                    </StackPanel>

                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="Validation" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.Schedules}"
                                  SelectedItem="{Binding ValidationSchedule}"
                                  Width="150" />
                    </StackPanel>

                    <StackPanel Margin="0,0,16,8">
                        <TextBlock Text="Notes" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:TextBox Text="{Binding Notes}" Width="250"
                                    PlaceholderText="Project notes..." />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,8" VerticalAlignment="Bottom">
                        <TextBlock Text=" " FontSize="12" Margin="0,0,0,4" />
                        <ui:Button Content="Save Manifest"
                                   Appearance="Primary"
                                   Command="{Binding SaveManifestCommand}" />
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
