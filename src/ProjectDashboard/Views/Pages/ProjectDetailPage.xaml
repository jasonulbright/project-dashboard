<Page
    x:Class="ProjectDashboard.Views.Pages.ProjectDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:ProjectDashboard.Helpers"
    xmlns:local="clr-namespace:ProjectDashboard.ViewModels.Pages">

    <Page.Resources>
        <helpers:RelativeTimeConverter x:Key="RelativeTimeConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="24,16">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="{Binding Project.DisplayName}"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding Project.LatestVersion}"
                           FontSize="14" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Ellipse Width="10" Height="10" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#4CAF50" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Project.GitStatus.IsDirty}" Value="True">
                                    <Setter Property="Fill" Value="#E8A317" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Clean" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Project.GitStatus.IsDirty}" Value="True">
                                    <Setter Property="Text" Value="Dirty" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Margin="16,0,0,0" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="{Binding Project.FullPath}" />
            </StackPanel>

            <!-- Row 1: README + Commits side by side -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="400" />
                </Grid.ColumnDefinitions>

                <!-- README -->
                <Border Grid.Column="0" Margin="0,0,12,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="400" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="README" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                            <TextBlock Text="{Binding ReadmeText}"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="12"
                                       TextWrapping="NoWrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Recent Commits -->
                <Border Grid.Column="1"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="400" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Recent Commits" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                            <ItemsControl ItemsSource="{Binding Commits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,4" Cursor="Hand"
                                                    ToolTip="Click to open on GitHub">
                                            <StackPanel.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.OpenCommitCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                              CommandParameter="{Binding}" />
                                            </StackPanel.InputBindings>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding ShortHash}"
                                                           FontFamily="Cascadia Code,Consolas"
                                                           FontSize="11"
                                                           Foreground="#6CA4D9"
                                                           TextDecorations="Underline"
                                                           Margin="0,0,8,0" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding Date, Converter={StaticResource RelativeTimeConverter}}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Text="{Binding Message}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </DockPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 2: CHANGELOG + GitHub Issues side by side -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="400" />
                </Grid.ColumnDefinitions>

                <!-- CHANGELOG -->
                <Border Grid.Column="0" Margin="0,0,12,0"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="300" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CHANGELOG" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                            <TextBlock Text="{Binding ChangelogText}"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="12"
                                       TextWrapping="NoWrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- GitHub Issues -->
                <Border Grid.Column="1"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="300" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="GitHub Issues" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                            <ItemsControl ItemsSource="{Binding Issues}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2,0,4" Cursor="Hand"
                                                   ToolTip="Click to open on GitHub">
                                            <DockPanel.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.OpenIssueCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                              CommandParameter="{Binding}" />
                                            </DockPanel.InputBindings>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontSize="12"
                                                       Foreground="#6CA4D9"
                                                       TextDecorations="Underline"
                                                       Cursor="Hand"
                                                       Margin="0,0,8,0">
                                                <Run Text="#" /><Run Text="{Binding Number, Mode=OneWay}" />
                                            </TextBlock>
                                            <Border DockPanel.Dock="Right"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="4" Padding="6,1"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{Binding State}" FontSize="10"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 3: Project Manifest Editor (full width, expanded) -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,4">
                        Project Manifest
                    </TextBlock>
                    <TextBlock Grid.Row="1" FontSize="12" Margin="0,0,0,12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               TextWrapping="Wrap">
                        Metadata stored in project-manifest.json at the project root. Controls how the dashboard categorizes, tracks, and schedules validation for this project.
                    </TextBlock>

                    <!-- Row of dropdowns -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,20,0" Width="160">
                            <TextBlock Text="Project Type" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.ProjectTypes}"
                                      SelectedItem="{Binding SelectedProjectType}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0" Width="160">
                            <TextBlock Text="Status" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.Statuses}"
                                      SelectedItem="{Binding SelectedStatus}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0" Width="160">
                            <TextBlock Text="Category" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.CategoriesList}"
                                      SelectedItem="{Binding SelectedCategory}" />
                        </StackPanel>

                        <StackPanel Width="160">
                            <TextBlock Text="Validation Schedule" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <ComboBox ItemsSource="{x:Static local:ProjectDetailViewModel.Schedules}"
                                      SelectedItem="{Binding ValidationSchedule}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Notes (full width, multi-line) -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,12">
                        <TextBlock Text="Notes" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13" />
                    </StackPanel>

                    <!-- Save button -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <ui:Button Content="Save Manifest"
                                   Appearance="Primary"
                                   Command="{Binding SaveManifestCommand}" />
                        <TextBlock Margin="12,0,0,0" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Saves to project-manifest.json in the project root" />
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
