<Page
    x:Class="ProjectDashboard.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:ProjectDashboard.Helpers">

    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" VerticalAlignment="Top" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="24" Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <!-- Theme -->
            <TextBlock Text="Theme" FontSize="16" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <RadioButton Content="Light" Margin="0,0,0,8"
                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light}"
                         Command="{Binding ChangeThemeCommand}"
                         CommandParameter="Light" />
            <RadioButton Content="Dark" Margin="0,0,0,24"
                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark}"
                         Command="{Binding ChangeThemeCommand}"
                         CommandParameter="Dark" />

            <!-- Projects Root Path -->
            <TextBlock Text="Projects Root Path" FontSize="16" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <DockPanel Margin="0,0,0,24">
                <ui:Button DockPanel.Dock="Right"
                           Content="Browse"
                           Command="{Binding BrowseFolderCommand}"
                           Margin="8,0,0,0" />
                <ui:TextBox Text="{Binding ProjectsRootPath, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="C:\projects" />
            </DockPanel>

            <!-- Refresh Interval -->
            <TextBlock Text="Refresh Interval (seconds)" FontSize="16" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <ui:TextBox Text="{Binding RefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="300"
                            Width="150" />
                <ui:Button Content="Sync Now"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Command="{Binding ForceSyncCommand}"
                           Margin="8,0,0,0" />
                <TextBlock Text="{Binding SyncStatus}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>

            <!-- Excluded Directories -->
            <TextBlock Text="Excluded Directories" FontSize="16" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="Comma-separated list of directory names to skip"
                       FontSize="12" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <ui:TextBox Text="{Binding ExcludedDirectories, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Internal, games, Archive"
                        Margin="0,0,0,24" />

            <!-- Save -->
            <ui:Button Content="Save Settings"
                       Appearance="Primary"
                       Command="{Binding SaveSettingsCommand}"
                       Margin="0,0,0,24" />

            <!-- GitHub Status -->
            <TextBlock Text="GitHub CLI Status" FontSize="16" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:SymbolIcon FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center">
                    <ui:SymbolIcon.Style>
                        <Style TargetType="ui:SymbolIcon">
                            <Setter Property="Symbol" Value="PlugDisconnected24" />
                            <Setter Property="Foreground" Value="{StaticResource StatusWarnFg}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GitHubStatus}" Value="Signed in">
                                    <Setter Property="Symbol" Value="PlugConnected24" />
                                    <Setter Property="Foreground" Value="{StaticResource StatusGoodFg}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding GitHubStatus}" Value="GitHub CLI not found">
                                    <Setter Property="Foreground" Value="{StaticResource StatusBadFg}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:SymbolIcon.Style>
                </ui:SymbolIcon>
                <TextBlock Text="{Binding GitHubStatus}"
                           FontSize="14" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:Button Content="Re-check" FontSize="12" Padding="8,4"
                           Command="{Binding RecheckGitHubCommand}"
                           Margin="12,0,0,0" />
            </StackPanel>
            <TextBlock FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="Repos show as &quot;local&quot; until gh is found and signed in (run: gh auth login). gh is delegated to for auth — the app never reads or stores your token. If gh is installed but not detected when launched from the Start Menu, point to gh.exe below." />
            <DockPanel Margin="0,0,0,24">
                <ui:Button DockPanel.Dock="Right"
                           Content="Browse"
                           Command="{Binding BrowseGhCommand}"
                           Margin="8,0,0,0" />
                <ui:TextBox Text="{Binding GhPath, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Auto-detect (leave blank to use PATH)" />
            </DockPanel>

            <!-- About -->
            <TextBlock Text="About" FontSize="16" Margin="0,24,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <StackPanel>
                <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                    <Run Text="Project Dashboard" FontWeight="SemiBold" />
                    <Run Text=" v1.1.1.1" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </TextBlock>
                <TextBlock Text="Fluent 2 WPF dashboard for local git repository management"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                    <Run Text="Built with WPF-UI, CommunityToolkit.Mvvm, .NET 10" />
                </TextBlock>
                <TextBlock FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                    <Run Text="Jason Ulbright" />
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
