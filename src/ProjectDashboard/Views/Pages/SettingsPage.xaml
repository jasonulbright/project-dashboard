<Page
    x:Class="ProjectDashboard.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:ProjectDashboard.Helpers">

    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" VerticalAlignment="Top" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="24" Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <!-- Theme -->
            <TextBlock Text="Theme" FontSize="16" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <RadioButton Content="Light" Margin="0,0,0,8"
                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light}"
                         Command="{Binding ChangeThemeCommand}"
                         CommandParameter="Light" />
            <RadioButton Content="Dark" Margin="0,0,0,24"
                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark}"
                         Command="{Binding ChangeThemeCommand}"
                         CommandParameter="Dark" />

            <!-- Projects Root Path -->
            <TextBlock Text="Projects Root Path" FontSize="16" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <DockPanel Margin="0,0,0,24">
                <ui:Button DockPanel.Dock="Right"
                           Content="Browse"
                           Command="{Binding BrowseFolderCommand}"
                           Margin="8,0,0,0" />
                <ui:TextBox Text="{Binding ProjectsRootPath, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="C:\projects" />
            </DockPanel>

            <!-- Refresh Interval -->
            <TextBlock Text="Refresh Interval (seconds)" FontSize="16" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <ui:TextBox Text="{Binding RefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="300"
                        Width="150"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,24" />

            <!-- Excluded Directories -->
            <TextBlock Text="Excluded Directories" FontSize="16" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="Comma-separated list of directory names to skip"
                       FontSize="12" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <ui:TextBox Text="{Binding ExcludedDirectories, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Internal, games, Archive"
                        Margin="0,0,0,24" />

            <!-- Save -->
            <ui:Button Content="Save Settings"
                       Appearance="Primary"
                       Command="{Binding SaveSettingsCommand}"
                       Margin="0,0,0,24" />

            <!-- GitHub Status -->
            <TextBlock Text="GitHub CLI Status" FontSize="16" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#E8A317" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GitHubStatus}" Value="Authenticated">
                                    <Setter Property="Fill" Value="#4CAF50" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding GitHubStatus}"
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
